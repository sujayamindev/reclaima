# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

# ─── OCI Authentication ───────────────────────────────────────────────────────
# All OCIDs: OCI Console → Profile (top-right avatar) → Tenancy / User Settings

tenancy_ocid         = "ocid1.tenancy.oc1..aaaaaaaa..."
oci_user_ocid        = "ocid1.user.oc1..aaaaaaaaa..."
oci_api_fingerprint  = "xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx"
oci_private_key_path = "~/.oci/oci_api_key.pem"
oci_region           = "ap-singapore-1"

# ─── OCI Compartment ─────────────────────────────────────────────────────────
# Use root compartment (same as tenancy_ocid) or a dedicated child compartment.

compartment_ocid = "ocid1.compartment.oc1..aaaaaaaaa..."

# ─── Compute (existing Always Free A1.Flex) ───────────────────────────────────

instance_ocpus      = 4
instance_memory_gb  = 24
boot_volume_size_gb = 50
data_volume_size_gb = 100

ssh_public_key       = "ssh-ed25519 AAAA..."
ssh_private_key_path = "~/.ssh/id_ed25519"

# Recommended: replace 0.0.0.0/0 with your own IP (e.g. "203.0.113.5/32")
ssh_allowed_cidr     = "0.0.0.0/0"
grafana_allowed_cidr = "0.0.0.0/0"

# ─── Existing OCI Resource OCIDs ─────────────────────────────────────────────
# Terraform imports these into state so it manages them without recreating.

instance_ocid          = "ocid1.instance.oc1.ap-singapore-1.aaaaaaaaa..."
vcn_ocid               = "ocid1.vcn.oc1.ap-singapore-1.aaaaaaaaa..."
igw_ocid               = "ocid1.internetgateway.oc1.ap-singapore-1.aaaaaaaaa..."
route_table_ocid       = "ocid1.routetable.oc1.ap-singapore-1.aaaaaaaaa..."
security_list_ocid     = "ocid1.securitylist.oc1.ap-singapore-1.aaaaaaaaa..."
subnet_ocid            = "ocid1.subnet.oc1.ap-singapore-1.aaaaaaaaa..."
data_volume_ocid       = "ocid1.volume.oc1.ap-singapore-1.aaaaaaaaa..."
volume_attachment_ocid = "ocid1.volumeattachment.oc1.ap-singapore-1.aaaaaaaaa..."

# ─── AWS ─────────────────────────────────────────────────────────────────────

aws_region     = "ap-southeast-1"
s3_bucket_name = "smart-receipt-storage"  # Must match AWS_S3_BUCKET in backend config
iam_user_name  = "reclaima-backend"       # The existing IAM user name in your AWS account

# ─── Infisical ───────────────────────────────────────────────────────────────

infisical_client_id     = ""   # INFISICAL_MACHINE_IDENTITY_CLIENT_ID
infisical_client_secret = ""   # INFISICAL_MACHINE_IDENTITY_CLIENT_SECRET
infisical_project_id    = ""   # INFISICAL_PROJECT_ID
infisical_env_slug      = "prod"
