# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_receipt_db

# ============================================
# Firebase Configuration
# ============================================
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Used by KrakenD gateway (not Python backend) for JWT issuer/audience validation.
# Set this in the shell or root .env before running docker-compose.
FIREBASE_PROJECT_ID=your-firebase-project-id

# ============================================
# AWS Configuration (Mock Mode for Development)
# ============================================
AWS_ACCESS_KEY_ID=mock_access_key
AWS_SECRET_ACCESS_KEY=mock_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=smart-receipt-storage
USE_MOCK_AWS=true

# ============================================
# Application Settings
# ============================================
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=true
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000,http://localhost:5173

# ============================================
# API Settings
# ============================================
API_V1_PREFIX=/api/v1
PROJECT_NAME=Smart Receipt & Warranty Manager
VERSION=0.1.0

# ============================================
# Background Scheduler
# ============================================
ENABLE_SCHEDULER=true
REMINDER_CHECK_HOUR=3  # Notification sending time: 3:00 AM UTC
CLEANUP_HOUR=2

# ============================================
# Security Settings
# ============================================
# JWT settings (for internal token generation if needed)
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# ============================================
# File Upload Settings
# ============================================
MAX_FILE_SIZE_MB=20
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_UPLOAD=10/hour
RATE_LIMIT_API=100/minute

# ============================================
# OCR Settings
# ============================================
OCR_MAX_RETRIES=3
OCR_RETRY_DELAY_SECONDS=5

# ============================================
# Notification Settings (Future)
# ============================================
WARRANTY_REMINDER_DAYS=30
RETURN_REMINDER_DAYS=3

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO

# ============================================
# Brave Search API (Product Image Lookup)
# ============================================
# Get your API key: https://api.search.brave.com/app#/developer/keys
# Free tier: 2,000 queries/month
BRAVE_SEARCH_API_KEY=
