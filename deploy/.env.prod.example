# Copy this file to /mnt/data/smart-receipt-and-warranty-manager/.env.prod on the OCI VM and update values.
# Non-sensitive runtime configuration only — secrets are managed by Infisical.
#
# ==============================================================================
# SECRETS — managed by Infisical (https://app.infisical.com), NOT set here
# ==============================================================================
# The variables below are absent from this file by design. They are fetched
# at deploy time or injected at application startup. Do NOT add them here.
#
#   POSTGRES_PASSWORD      — fetched by oci_deploy.sh (Infisical CLI); single
#                            source of truth for the DB password
#   DATABASE_URL           — CONSTRUCTED by oci_deploy.sh from POSTGRES_USER +
#                            POSTGRES_DB (here) and POSTGRES_PASSWORD (Infisical).
#                            Do NOT store DATABASE_URL separately in Infisical —
#                            it would drift from POSTGRES_PASSWORD on rotation.
#   AWS_ACCESS_KEY_ID      — injected by Infisical SDK at app startup
#   AWS_SECRET_ACCESS_KEY  — injected by Infisical SDK at app startup
#   SECRET_KEY             — injected by Infisical SDK at app startup
#   BRAVE_SEARCH_API_KEY   — injected by Infisical SDK at app startup
# ==============================================================================

# Database identifiers (non-sensitive). POSTGRES_USER MUST match the role that
# exists in the postgres data volume; oci_deploy.sh embeds it into DATABASE_URL.
POSTGRES_USER=sujaya
POSTGRES_DB=smart_receipt_db

# Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Consumed by KrakenD for JWT validation — not read by the Python app
FIREBASE_PROJECT_ID=your-firebase-project-id

# AWS Configuration (keys are in Infisical)
AWS_REGION=us-east-1
AWS_S3_BUCKET=smart-receipt-storage
USE_MOCK_AWS=false

# Application
DEBUG=false
ALLOWED_ORIGINS=https://your-mobile-api-origin.example
API_V1_PREFIX=/api/v1
PROJECT_NAME=Smart Receipt & Warranty Manager
VERSION=0.1.0
LOG_LEVEL=INFO

# JWT/Auth
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# Upload and OCR
MAX_FILE_SIZE_MB=5
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf
OCR_MAX_RETRIES=3
OCR_RETRY_DELAY_SECONDS=5

# Scheduler and reminder timing
ENABLE_SCHEDULER=false
REMINDER_CHECK_HOUR=3
CLEANUP_HOUR=2
WARRANTY_REMINDER_DAYS=30
RETURN_REMINDER_DAYS=3

# Runtime tuning
API_PORT=8000
API_WORKERS=2

# Container resources (standalone compose + swarm-compatible deploy.resources)
# API service
API_CPU_RESERVATION=1.00
API_MEM_RESERVATION=1024M

# Scheduler service
SCHEDULER_CPU_RESERVATION=0.25
SCHEDULER_MEM_RESERVATION=512M

# Migration one-off service
MIGRATE_CPU_RESERVATION=0.10
MIGRATE_MEM_RESERVATION=128M

# PostgreSQL service
POSTGRES_CPU_RESERVATION=0.50
POSTGRES_MEM_RESERVATION=768M
