# Copy this file to /opt/smart-receipt/.env.prod on the OCI VM and update values.

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=smart_receipt_db
DATABASE_URL=postgresql://postgres:change-this-password@postgres:5432/smart_receipt_db

# Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# AWS Configuration
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1
AWS_S3_BUCKET=smart-receipt-storage
USE_MOCK_AWS=false

# Application
SECRET_KEY=replace-with-long-random-secret
DEBUG=false
ALLOWED_ORIGINS=https://your-mobile-api-origin.example
API_V1_PREFIX=/api/v1
PROJECT_NAME=Smart Receipt & Warranty Manager
VERSION=0.1.0
LOG_LEVEL=INFO

# JWT/Auth
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# Upload and OCR
MAX_FILE_SIZE_MB=5
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf
OCR_MAX_RETRIES=3
OCR_RETRY_DELAY_SECONDS=5

# Scheduler and reminder timing
ENABLE_SCHEDULER=false
REMINDER_CHECK_HOUR=3
CLEANUP_HOUR=2
WARRANTY_REMINDER_DAYS=30
RETURN_REMINDER_DAYS=3

# Optional
BRAVE_SEARCH_API_KEY=

# Runtime tuning
API_PORT=8000
API_WORKERS=2
