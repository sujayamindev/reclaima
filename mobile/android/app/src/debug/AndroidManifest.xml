<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Needed by MainActivityTest to acquire a FULL_WAKE_LOCK so the
         instrumentation runner keeps the screen on during E2E tests.
         Without this, the device sleeps mid-test and no results are recorded. -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.DISABLE_KEYGUARD"/>

    <!-- Debug-only: allow cleartext HTTP so E2E tests can reach the backend VM
         (http://168.138.170.92:8000) and the local Firebase Admin test helper
         (http://10.0.2.2:<port>). Production (main manifest) is unaffected. -->
    <application
        android:usesCleartextTraffic="true"
        tools:replace="android:usesCleartextTraffic"/>
</manifest>
